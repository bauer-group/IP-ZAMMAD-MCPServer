# =============================================================================
# Zammad MCP Server — Environment Configuration
# =============================================================================
# Remote MCP server bridging a self-hosted Zammad (v6.x / v7.x) helpdesk to
# AI clients (Claude Web, Claude Desktop, Microsoft 365 Copilot, ChatGPT,
# Cursor, ...).
#
# - Inbound (AI client -> MCP):  OAuth 2.1 + PKCE via Zammad (or external OIDC)
# - Outbound (MCP -> Zammad):    user's bearer token (zammad mode) or
#                                static ZAMMAD_API_TOKEN (oidc / none modes)
#
# /!\ BEFORE FIRST START - replace EVERY value containing "CHANGE_ME" /!\
#
# One-shot, cross-platform (Windows / Linux / macOS):
#
#     python scripts/generate-env.py
#
# Deployment:
#   Local development:   docker compose -f docker-compose.development.yml up -d
#   Self-hosted Traefik: docker compose -f docker-compose.traefik.yml      up -d
#   Coolify:             configure env in dashboard -> docker-compose.coolify.yml
# =============================================================================


# =============================================================================
# Stack Configuration
# =============================================================================

STACK_NAME=bg-zammad-mcp
TIME_ZONE=Etc/UTC

# production | staging | development
# AUTH_MODE=none is only permitted when ENVIRONMENT=development.
ENVIRONMENT=production


# =============================================================================
# Image
# =============================================================================

ZAMMAD_MCP_IMAGE=ghcr.io/bauer-group/ip-zammad-mcpserver/bg-zammad-mcp
ZAMMAD_MCP_VERSION=latest

# Redis (OAuth client storage - required in production for restart-safe sessions)
REDIS_IMAGE=redis
REDIS_VERSION=8-alpine

# Redis memory caps - SAFETY LIMITS, not reservations. The actual OAuth
# working set is tiny (a few KB per registered DCR client, plus issued tokens).
REDIS_MAXMEMORY=256mb
REDIS_CONTAINER_MEM_LIMIT=384m


# =============================================================================
# Hostnames & URLs (Traefik / Coolify only)
# =============================================================================

# Public hostname of the MCP server - Let's Encrypt resolves this for HTTPS.
ZAMMAD_MCP_HOSTNAME=zammad-mcp.example.com

# External Traefik network name (must already exist on the Docker host)
PROXY_NETWORK=EDGEPROXY

# Full public base URL - used in OAuth redirect URIs and protected-resource
# metadata. MUST exactly match what your IdP has registered (case, scheme,
# trailing slash).
PUBLIC_BASE_URL=https://${ZAMMAD_MCP_HOSTNAME}


# =============================================================================
# Local Ports (development only)
# =============================================================================

ZAMMAD_MCP_PORT=8000

# Redis port exposure (development convenience - leave empty to keep redis internal)
REDIS_PORT=6379


# =============================================================================
# Zammad Backend (REQUIRED, used for every outbound call)
# =============================================================================
# Configure ZAMMAD_URL. The MCP supports BOTH Zammad v6.x and v7.x - the
# /api/v1 surface is shared. The container probes /api/v1/version at startup
# to log the live major version (informational only).
#
# Examples:
#   http://zammad:3000                       (same Docker network as Zammad)
#   https://support.bauer-group.com          (public Zammad instance)
ZAMMAD_URL=http://zammad:3000

# Static Zammad API token (Personal Access Token). Required in oidc / none
# AUTH_MODE. In zammad mode LEAVE THIS EMPTY: per-user tokens are forwarded
# instead, and a value here becomes a silent fallback (calls would run as
# this token whenever a per-user token is missing), defeating per-user OBO.
# Generate in Zammad: avatar menu -> Profile -> Token Access -> Create.
# Suggested permissions: ticket.agent + user.reader  (or full admin for
# automation-only deployments).
ZAMMAD_API_TOKEN=

# Per-request timeout to Zammad (seconds)
ZAMMAD_HTTP_TIMEOUT=30

# Verify Zammad's TLS certificate. Only set to false for self-signed dev
# instances - never in production.
ZAMMAD_VERIFY_TLS=true


# =============================================================================
# MCP Server
# =============================================================================

# Transport - only 'streamable-http' makes sense for a remote MCP server.
MCP_TRANSPORT=streamable-http

# Bind address. Leave empty for dual-stack on any interface (default).
MCP_HOST=
MCP_PORT=8000

# Log format: console (dev, Rich-coloured) or json (prod, aggregator-friendly)
LOG_FORMAT=json
LOG_LEVEL=INFO


# =============================================================================
# Consent screen branding (OAuth dialog shown to end users)
# =============================================================================

MCP_DISPLAY_NAME=BAUER GROUP Zammad
MCP_ICON_URL=
MCP_WEBSITE_URL=https://go.bauer-group.com/mcp-server


# =============================================================================
# Auth Mode - pick ONE
# =============================================================================
# Valid:
#   zammad - Zammad IS the OAuth2 provider (PRIMARY, recommended).
#            User-context: the user's Zammad access token is forwarded to
#            every API call, so Zammad's permission system enforces access.
#   oidc   - External OIDC IdP (Entra / Keycloak / Authentik / Zitadel /
#            Auth0 / Okta) handles authentication. Zammad calls use the
#            static ZAMMAD_API_TOKEN (single Zammad identity for every user).
#   none   - Dev only. Requires ENVIRONMENT=development. Uses ZAMMAD_API_TOKEN.

AUTH_MODE=zammad


# =============================================================================
# Auth: Zammad as OAuth2 provider  (AUTH_MODE=zammad)
# =============================================================================
# Operator setup (one-time, in Zammad):
#   1. Sign in to Zammad as an Admin
#   2. Admin -> Manage -> OAuth2 Applications -> Add
#   3. Configure:
#        Name:            BAUER GROUP MCP   (or your preferred display name)
#        Redirect URI:    ${PUBLIC_BASE_URL}/auth/callback
#        Scopes:          read write
#        Confidential:    Yes
#   4. Save - copy the generated Client ID and Client Secret below.
#
# The "OAuth2 Applications" feature ships with Zammad v6.0 and later.
# Earlier releases (3.x / 4.x / 5.x) lack the UI - use AUTH_MODE=oidc with
# a static ZAMMAD_API_TOKEN there.

ZAMMAD_OAUTH_CLIENT_ID=
ZAMMAD_OAUTH_CLIENT_SECRET=

# Scope set requested from the user during the consent flow. Zammad's
# OAuth2 application configuration limits this to 'read' and 'write'.
ZAMMAD_OAUTH_SCOPES=read write

# Endpoint paths - overridable only when Zammad is mounted on a non-default path
# (reverse proxy with a sub-path). Leave defaults otherwise.
ZAMMAD_OAUTH_AUTHORIZE_PATH=/oauth/authorize
ZAMMAD_OAUTH_TOKEN_PATH=/oauth/token
ZAMMAD_USERINFO_PATH=/api/v1/users/me


# =============================================================================
# Auth: External OIDC (Entra / Keycloak / Authentik / ...)  (AUTH_MODE=oidc)
# =============================================================================
# Redirect URI to register with the IdP: ${PUBLIC_BASE_URL}/auth/callback
#
# Either set OIDC_DISCOVERY_URL and the loader pulls endpoints automatically,
# or set each OIDC_*_URI explicitly. Discovery is preferred - it picks up
# JWKS rotations transparently.

OIDC_DISCOVERY_URL=
# Example: OIDC_DISCOVERY_URL=https://id.bauer-group.com/application/o/zammad-mcp/.well-known/openid-configuration

OIDC_ISSUER=
OIDC_AUTH_URI=
OIDC_TOKEN_URI=
OIDC_JWKS_URI=
OIDC_USERINFO_URI=

OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

OIDC_SCOPES=openid profile email
OIDC_USERNAME_CLAIM=preferred_username


# =============================================================================
# Role-based MCP access
# =============================================================================
# Which Zammad role names may use this MCP at all. Case-insensitive,
# comma-separated.
#
# Common configurations:
#   Admin,Agent             - Internal MCP for agents and admins (DEFAULT)
#   Admin                   - Admins only (highly privileged automation)
#   Customer                - Self-service MCP for customers
#   Admin,Agent,Customer    - Anyone with a Zammad account (review carefully)
#
# Leave empty to allow ANY authenticated Zammad user. NOT recommended in
# production because customer accounts can be self-registered in some setups.
#
# Only enforced in AUTH_MODE=zammad - external OIDC tokens don't carry
# Zammad role info, so this is a no-op in AUTH_MODE=oidc/none. Zammad's own
# permission system enforces fine-grained access in every mode.
MCP_ALLOWED_ROLES=Admin,Agent

# Audit-only mode: role denials are logged but the request is allowed
# through. Use during rollout to verify the allowlist matches reality
# before switching to enforcement.
MCP_ROLE_CHECK_AUDIT_ONLY=false


# =============================================================================
# OAuth Persistence
# =============================================================================
# OAuth state (DCR clients, refresh tokens, auth codes, JTI mappings + the
# upstream Zammad tokens we forward at tool-call time) must survive
# container restarts - otherwise every client re-registers and every user
# re-authenticates after a deploy.
#
# Two backends, both encrypted at rest:
#   - Redis-backed (recommended for production):
#       AUTH_REDIS_URL=redis://redis:6379/0
#       AUTH_STORAGE_ENCRYPTION_KEY=<fernet-key>   (operator-controlled)
#   - Disk-backed (fallback when no Redis is available):
#       AUTH_REDIS_URL=                            (empty)
#       AUTH_DISK_STORAGE_PATH=/app/data/oauth-storage
#       Encryption key is derived from AUTH_JWT_SIGNING_KEY via HKDF.
#       MOUNT THE PATH AS A DOCKER VOLUME, otherwise state is wiped on every
#       container restart.

# JWT signing key — used to sign FastMCP-issued tokens AND (in disk mode) to
# derive the storage encryption key. Must survive restarts.
#   openssl rand -hex 32
AUTH_JWT_SIGNING_KEY=CHANGE_ME_AUTH_JWT_SIGNING_KEY

# Redis URL for OAuth client-registration storage. Leave empty to use the
# encrypted disk-storage fallback at AUTH_DISK_STORAGE_PATH.
AUTH_REDIS_URL=redis://redis:6379/0

# Fernet key for at-rest encryption of stored OAuth state in Redis mode.
# REQUIRED when AUTH_REDIS_URL is set; ignored in disk mode.
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AUTH_STORAGE_ENCRYPTION_KEY=CHANGE_ME_AUTH_STORAGE_ENCRYPTION_KEY

# Filesystem path for the encrypted disk-storage fallback.
AUTH_DISK_STORAGE_PATH=/app/data/oauth-storage


# =============================================================================
# Rate Limiting
# =============================================================================
# Token-bucket limiter applied on every MCP request - cheapest rejection
# path under load. Keyed per-client when possible:
#   - authenticated requests  -> OAuth subject (`sub` / Entra `oid`)
#   - anonymous requests      -> source IP (X-Forwarded-For, see below)
#   - stdio transport         -> single shared bucket "ip:local"

RATE_LIMITER_ENABLED=true
RATE_LIMITER_MAX_REQUESTS_PER_SECOND=10
RATE_LIMITER_BURST_CAPACITY=20
RATE_LIMITER_GLOBAL=false

# Number of trusted reverse-proxy hops in front of this server.
#   0  - No proxy. XFF is ignored; request.client.host is used.
#   1  - Direct Traefik / Coolify default. (DEFAULT)
#   2  - Cloudflare -> Traefik. Or any 2-hop edge -> ingress chain.
RATE_LIMITER_TRUSTED_PROXY_HOPS=1


# =============================================================================
# Observability
# =============================================================================
# Sentry error tracking (optional - leave SENTRY_DSN empty to disable)

SENTRY_DSN=
SENTRY_ENVIRONMENT=${ENVIRONMENT}
SENTRY_TRACES_SAMPLE_RATE=0.05
